﻿﻿﻿﻿﻿{
  "packages":[
    {
      "appRoutingModuleConfiguration":{
        "imports":[
          {
            "names":[
              "EXTRACT_ROUTES"
            ],
            "namespace": "@dignite/extract"
          } 
        ],
        "routes":[
          "{ path: 'extract', children: EXTRACT_ROUTES, canActivate: [authGuard] }"
        ]
      },
      "appModuleConfiguration":{
        "imports":[
          {
            "names":[
              "provideExtract"
            ],
            "namespace": "@dignite/extract/config"
          }
        ],
        "providerNames":[
          "provideExtract()"
        ]
      },
      "tsJsonPathRecordConfigurations":[
        {
          "name": "@dignite/extract",
          "paths": [
            "angular/packages/extract/src/public-api.ts"
          ]
        },
        {
          "name": "@dignite/extract/config",
          "paths": [
            "angular/packages/extract/config/src/public-api.ts"
          ]
        }
      ]
    }
  ]
}