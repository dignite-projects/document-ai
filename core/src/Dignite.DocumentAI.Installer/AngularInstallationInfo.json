{
  "packages":[
    {
      "appRoutingModuleConfiguration":{
        "imports":[
          {
            "names":[
              "PAPERBASE_ROUTES"
            ],
            "namespace": "@dignite/paperbase"
          } 
        ],
        "routes":[
          "{ path: 'paperbase', children: PAPERBASE_ROUTES, canActivate: [authGuard] }"
        ]
      },
      "appModuleConfiguration":{
        "imports":[
          {
            "names":[
              "providePaperbase"
            ],
            "namespace": "@dignite/paperbase/config"
          }
        ],
        "providerNames":[
          "providePaperbase()"
        ]
      },
      "tsJsonPathRecordConfigurations":[
        {
          "name": "@dignite/paperbase",
          "paths": [
            "angular/projects/paperbase/src/public-api.ts"
          ]
        },
        {
          "name": "@dignite/paperbase/config",
          "paths": [
            "angular/projects/paperbase/config/src/public-api.ts"
          ]
        }
      ]
    }
  ]
}