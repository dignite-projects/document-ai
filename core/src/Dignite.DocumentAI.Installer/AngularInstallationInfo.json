{
  "packages":[
    {
      "appRoutingModuleConfiguration":{
        "imports":[
          {
            "names":[
              "DOCUMENTAI_ROUTES"
            ],
            "namespace": "@dignite/document-ai"
          } 
        ],
        "routes":[
          "{ path: 'document-ai', children: DOCUMENTAI_ROUTES, canActivate: [authGuard] }"
        ]
      },
      "appModuleConfiguration":{
        "imports":[
          {
            "names":[
              "provideDocumentAI"
            ],
            "namespace": "@dignite/document-ai/config"
          }
        ],
        "providerNames":[
          "provideDocumentAI()"
        ]
      },
      "tsJsonPathRecordConfigurations":[
        {
          "name": "@dignite/document-ai",
          "paths": [
            "angular/packages/document-ai/src/public-api.ts"
          ]
        },
        {
          "name": "@dignite/document-ai/config",
          "paths": [
            "angular/packages/document-ai/config/src/public-api.ts"
          ]
        }
      ]
    }
  ]
}