{
  "App": {
    "SelfUrl": "https://localhost:44348",
    "ClientUrl": "http://localhost:4200",
    "CorsOrigins": "https://*.Extract.com,http://localhost:4200,http://localhost:6274",
    "RedirectAllowedUrls": "http://localhost:4200",
    "HealthCheckUrl": "/health-status"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": ["FromLogContext"],
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "Logs/logs.txt"
              }
            }
          ]
        }
      },
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ]
  },
  "ConnectionStrings": {
    "Default": "Server=(LocalDb)\\MSSQLLocalDB;Database=Extract;Trusted_Connection=True;TrustServerCertificate=true"
  },
  "Extract": {
    "Endpoint": "https://api.openai.com/v1",
    "ApiKey": "YOUR_API_KEY",
    "ChatModelId": "gpt-4o-mini",
    "TitleGeneratorModelId": "gpt-4o-mini",
    "StructuredModelId": "gpt-4o-mini",
    "VisionOcrModelId": "gpt-4o-mini"
  },
  "ExtractBehavior": {
    "DefaultLanguage": "ja",
    "MaxDocumentTypesInClassificationPrompt": 50,
    "MaxTextLengthPerExtraction": 8000
  },
  "VisionLlmOcr": {
    "MaxOutputTokens": 4096,
    "MaxPdfPages": 30
  },
  "PaddleOcr": {
    "Endpoint": "http://localhost:8866",
    "ModelName": "PP-StructureV3",
    "Languages": [ "ja", "en" ]
  },
  "OpenXmlExtractor": {
    "MaxImagesPerFile": 50,
    "MinImagePixels": 4096,
    "MaxImageBytesPerImage": 16777216,
    "IncludeSpeakerNotes": false
  },
  "AuthServer": {
    "Authority": "https://localhost:44348",
    "RequireHttpsMetadata": true,
    "SwaggerClientId": "Extract_Swagger",
    "CertificatePassPhrase": ""
  },
  "OpenTelemetry": {
    "Enabled": false,
    "ConsoleExporter": false,
    "Otlp": {
      "Endpoint": "http://localhost:4317",
      "Protocol": "Grpc"
    }
  },
  "Settings": {
    "Abp.Identity.Password.RequireNonAlphanumeric": "false",
    "Abp.Identity.Password.RequireLowercase": "false",
    "Abp.Identity.Password.RequireUppercase": "false",
    "Abp.Identity.Password.RequireDigit": "false"
  },
  "StringEncryption": {
    "DefaultPassPhrase": ""
  },
  "OpenIddict": {
    "Applications": {
      "Extract_App": {
        "ClientId": "Extract_App",
        "RootUrl": "http://localhost:4200"
      },
      "Extract_Swagger": {
        "ClientId": "Extract_Swagger",
        "RootUrl": "https://localhost:44348"
      },
      "Extract_Mcp": {
        "ClientId": "Extract_Mcp"
      }
    }
  }
}
